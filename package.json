    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.14"
